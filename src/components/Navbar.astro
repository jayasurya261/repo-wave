---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname === '/' ? '/' : pathname;
---
<nav class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 sticky top-0 z-50 transition-colors duration-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
            <div class="flex">
                <div class="flex-shrink-0 flex items-center">
                    <a href="/" class="flex items-center">
                        <img src="https://res.cloudinary.com/dqudvximt/image/upload/v1771714384/Untitled-1_wxhwey.png" alt="App Logo" class="h-10 md:h-14 w-auto dark:brightness-90">
                    </a>
                </div>
                <div class="hidden sm:ml-6 sm:flex sm:space-x-4 lg:space-x-8">
                    <a href="/" class={`${currentPath === '/' ? 'border-green-500 text-gray-900 dark:text-white' : 'border-transparent text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} inline-flex items-center px-1 pt-1 border-b-4 text-sm font-medium transition-colors`}>
                        DASHBOARD
                    </a>
                    <a href="/issues" class={`${currentPath.startsWith('/issues') ? 'border-green-500 text-gray-900 dark:text-white' : 'border-transparent text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} inline-flex items-center px-1 pt-1 border-b-4 text-sm font-medium transition-colors`}>
                        ISSUES
                    </a>
                    <a href="/repositories" class={`${currentPath.startsWith('/repositories') ? 'border-green-500 text-gray-900 dark:text-white' : 'border-transparent text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} inline-flex items-center px-1 pt-1 border-b-4 text-sm font-medium transition-colors`}>
                        REPOSITORIES
                    </a>
                    <a href="/bookmarks" class={`${currentPath.startsWith('/bookmarks') ? 'border-green-500 text-gray-900 dark:text-white' : 'border-transparent text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} inline-flex items-center px-1 pt-1 border-b-4 text-sm font-medium transition-colors`}>
                        BOOKMARKS
                    </a>
                    <a href="/favourites" class={`${currentPath.startsWith('/favourites') ? 'border-green-500 text-gray-900 dark:text-white' : 'border-transparent text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} inline-flex items-center px-1 pt-1 border-b-4 text-sm font-medium transition-colors`}>
                        FAVOURITES
                    </a>
                    <a href="/guide" class={`${currentPath.startsWith('/guide') ? 'border-green-500 text-gray-900 dark:text-white' : 'border-transparent text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} inline-flex items-center px-1 pt-1 border-b-4 text-sm font-medium transition-colors`}>
                        GUIDE
                    </a>
                    <!-- More dropdown (hover) -->
                    <div class="group relative flex items-stretch self-stretch" id="more-dropdown-wrapper">
                        <button
                            type="button"
                            class={`${currentPath.startsWith('/about') || currentPath.startsWith('/privacy') || currentPath.startsWith('/terms') || currentPath.startsWith('/contact') ? 'border-green-500 text-gray-900 dark:text-white' : 'border-transparent text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} inline-flex items-center gap-1 px-1 pt-1 border-b-4 text-sm font-medium transition-colors focus:outline-none h-full cursor-default`}
                        >
                            MORE
                            <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </button>
                        <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-150 absolute top-full left-0 w-44 bg-white dark:bg-gray-900 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700 py-1 z-50">
                            <a href="/about" class={`flex items-center gap-2 px-4 py-2.5 text-sm font-medium transition-colors ${currentPath.startsWith('/about') ? 'text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20' : 'text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-indigo-600 dark:hover:text-indigo-400'}`}>
                                About Us
                            </a>
                            <a href="/privacy-policy" class={`flex items-center gap-2 px-4 py-2.5 text-sm font-medium transition-colors ${currentPath.startsWith('/privacy-policy') ? 'text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20' : 'text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-indigo-600 dark:hover:text-indigo-400'}`}>
                                Privacy Policy
                            </a>
                            <a href="/terms" class={`flex items-center gap-2 px-4 py-2.5 text-sm font-medium transition-colors ${currentPath.startsWith('/terms') ? 'text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20' : 'text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-indigo-600 dark:hover:text-indigo-400'}`}>
                                Terms of Service
                            </a>
                            <a href="/contact" class={`flex items-center gap-2 px-4 py-2.5 text-sm font-medium transition-colors ${currentPath.startsWith('/contact') ? 'text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20' : 'text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-indigo-600 dark:hover:text-indigo-400'}`}>
                                Contact
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="flex items-center space-x-1 lg:space-x-2">

                <!-- Dark mode toggle -->
                <button
                    id="theme-toggle"
                    type="button"
                    aria-label="Toggle dark mode"
                    class="p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors focus:outline-none focus:ring-2 focus:ring-green-500"
                >
                    <!-- Sun icon (shown in dark mode) -->
                    <svg id="theme-icon-sun" class="hidden h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 7a5 5 0 100 10A5 5 0 0012 7z"/>
                    </svg>
                    <!-- Moon icon (shown in light mode) -->
                    <svg id="theme-icon-moon" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                    </svg>
                </button>

                <a href="https://github.com/jayasurya261/repo-wave" target="_blank" rel="noopener noreferrer" class="text-gray-800 dark:text-gray-200 hover:text-black dark:hover:text-white transition-colors hidden lg:block" title="View on GitHub">
                    <span class="sr-only">GitHub</span>
                    <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                    </svg>
                </a>

                <!-- Auth Section Desktop -->
                <div id="auth-section-desktop" class="hidden sm:flex items-center gap-2 ml-1 pl-2 border-l border-gray-200 dark:border-gray-700">
                    <div id="unauth-desktop" class="hidden items-center gap-2">
                        <!-- login/signup hidden -->
                    </div>
                    <div id="auth-desktop" class="hidden items-center gap-2">
                        <!-- Avatar with initials fallback -->
                        <a href="/profile" class="relative group block" title="View Profile">
                            <img id="user-avatar-desktop" class="h-8 w-8 rounded-full hidden border-2 border-green-400 cursor-pointer object-cover" src="" alt="Avatar" />
                            <div id="user-initials-desktop" class="h-8 w-8 rounded-full bg-green-500 flex items-center justify-center cursor-pointer border-2 border-green-400">
                                <span id="user-initial-text" class="text-white text-xs font-bold"></span>
                            </div>
                        </a>
                        <button id="logout-btn-desktop" class="text-sm font-medium text-gray-500 hover:text-red-600 dark:text-gray-400 dark:hover:text-red-400 transition-colors whitespace-nowrap">Log out</button>
                    </div>
                </div>

                <!-- Mobile menu button -->
                <div class="flex items-center sm:hidden">
                    <button type="button" id="mobile-menu-btn" class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 dark:text-gray-500 hover:text-gray-500 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-green-500" aria-expanded="false">
                        <span class="sr-only">Open main menu</span>
                        <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Mobile menu -->
    <div class="sm:hidden hidden bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800" id="mobile-menu">
        <div class="pt-2 pb-3 space-y-1">
            <a href="/" class={`${currentPath === '/' ? 'bg-green-50 dark:bg-green-900/20 border-green-500 text-green-700 dark:text-green-400' : 'border-transparent text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} block pl-3 pr-4 py-2 border-l-4 text-base font-medium transition-colors`}>
                DASHBOARD
            </a>
            <a href="/issues" class={`${currentPath.startsWith('/issues') ? 'bg-green-50 dark:bg-green-900/20 border-green-500 text-green-700 dark:text-green-400' : 'border-transparent text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} block pl-3 pr-4 py-2 border-l-4 text-base font-medium transition-colors`}>
                ISSUES
            </a>
            <a href="/repositories" class={`${currentPath.startsWith('/repositories') ? 'bg-green-50 dark:bg-green-900/20 border-green-500 text-green-700 dark:text-green-400' : 'border-transparent text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} block pl-3 pr-4 py-2 border-l-4 text-base font-medium transition-colors`}>
                REPOSITORIES
            </a>
            <a href="/bookmarks" class={`${currentPath.startsWith('/bookmarks') ? 'bg-green-50 dark:bg-green-900/20 border-green-500 text-green-700 dark:text-green-400' : 'border-transparent text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} block pl-3 pr-4 py-2 border-l-4 text-base font-medium transition-colors`}>
                BOOKMARKS
            </a>
            <a href="/favourites" class={`${currentPath.startsWith('/favourites') ? 'bg-green-50 dark:bg-green-900/20 border-green-500 text-green-700 dark:text-green-400' : 'border-transparent text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} block pl-3 pr-4 py-2 border-l-4 text-base font-medium transition-colors`}>
                FAVOURITES
            </a>
            <a href="/guide" class={`${currentPath.startsWith('/guide') ? 'bg-green-50 dark:bg-green-900/20 border-green-500 text-green-700 dark:text-green-400' : 'border-transparent text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} block pl-3 pr-4 py-2 border-l-4 text-base font-medium transition-colors`}>
                GUIDE
            </a>
            <a href="/about" class={`${currentPath.startsWith('/about') ? 'bg-green-50 dark:bg-green-900/20 border-green-500 text-green-700 dark:text-green-400' : 'border-transparent text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} block pl-3 pr-4 py-2 border-l-4 text-base font-medium transition-colors`}>
                ABOUT US
            </a>
            <a href="/privacy-policy" class={`${currentPath.startsWith('/privacy-policy') ? 'bg-green-50 dark:bg-green-900/20 border-green-500 text-green-700 dark:text-green-400' : 'border-transparent text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} block pl-3 pr-4 py-2 border-l-4 text-base font-medium transition-colors`}>
                PRIVACY POLICY
            </a>
            <a href="/terms" class={`${currentPath.startsWith('/terms') ? 'bg-green-50 dark:bg-green-900/20 border-green-500 text-green-700 dark:text-green-400' : 'border-transparent text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 hover:text-gray-700 dark:hover:text-gray-200'} block pl-3 pr-4 py-2 border-l-4 text-base font-medium transition-colors`}>
                TERMS
            </a>
        </div>
        
        <!-- Auth Section Mobile -->
        <div id="auth-section-mobile" class="pt-4 pb-3 border-t border-gray-200 dark:border-gray-800">
            <div id="unauth-mobile" class="hidden space-y-1 px-2">
                <!-- login/signup hidden -->
            </div>
            <div id="auth-mobile" class="hidden px-4">
                <a href="/profile" class="flex items-center group block">
                    <img id="user-avatar-mobile" class="h-10 w-10 rounded-full hidden border border-gray-200 dark:border-gray-700 object-cover" src="" alt="Avatar" />
                    <div id="user-initials-mobile" class="h-10 w-10 rounded-full bg-green-500 hidden items-center justify-center border border-gray-200 dark:border-gray-700">
                        <span id="user-initial-text-mobile" class="text-white text-sm font-bold"></span>
                    </div>
                    <div class="ml-3 group-hover:opacity-80 transition-opacity">
                        <div id="user-name-mobile" class="text-base font-medium text-gray-800 dark:text-white"></div>
                        <div id="user-email-mobile" class="text-sm font-medium text-gray-500 dark:text-gray-400">View Profile</div>
                    </div>
                </a>
                <div class="mt-3 space-y-1">
                    <button id="logout-btn-mobile" class="block w-full text-left px-3 py-2 rounded-md text-base font-medium text-red-500 hover:text-red-700 hover:bg-gray-50 dark:hover:bg-gray-800">Log out</button>
                </div>
            </div>
        </div>
    </div>
</nav>

<script>
    // Mobile menu toggle
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && menu) {
        btn.addEventListener('click', () => menu.classList.toggle('hidden'));
    }

    // Dark mode toggle
    const themeBtn = document.getElementById('theme-toggle');
    const sunIcon = document.getElementById('theme-icon-sun');
    const moonIcon = document.getElementById('theme-icon-moon');

    function applyTheme(dark) {
        document.documentElement.classList.toggle('dark', dark);
        localStorage.setItem('theme', dark ? 'dark' : 'light');
        if (sunIcon) sunIcon.classList.toggle('hidden', !dark);
        if (moonIcon) moonIcon.classList.toggle('hidden', dark);
    }

    // Sync icon state on load
    const isDark = document.documentElement.classList.contains('dark');
    if (sunIcon) sunIcon.classList.toggle('hidden', !isDark);
    if (moonIcon) moonIcon.classList.toggle('hidden', isDark);

    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
            applyTheme(!document.documentElement.classList.contains('dark'));
        });
    }
</script>

<script>
    // More dropdown toggle
    function initMoreDropdown() {
        const btn = document.getElementById('more-dropdown-btn');
        const menu = document.getElementById('more-dropdown-menu');
        const chevron = document.getElementById('more-dropdown-chevron');
        if (!btn || !menu) return;

        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const isOpen = !menu.classList.contains('hidden');
            menu.classList.toggle('hidden', isOpen);
            if (chevron) chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
        });

        // Close when clicking outside
        document.addEventListener('click', () => {
            menu.classList.add('hidden');
            if (chevron) chevron.style.transform = '';
        });
    }

    initMoreDropdown();
    document.addEventListener('astro:page-load', initMoreDropdown);
</script>

<script>
    import { authClient } from '../lib/auth-client';

    async function checkAuth() {
        try {
            const { data: sessionData } = await authClient.getSession();
            
            const unauthDesktop = document.getElementById('unauth-desktop');
            const authDesktop = document.getElementById('auth-desktop');
            const unauthMobile = document.getElementById('unauth-mobile');
            const authMobile = document.getElementById('auth-mobile');
            
            if (sessionData && sessionData.user) {
                // Compute shared values at the top
                const displayName = sessionData.user.name || sessionData.user.email.split('@')[0];
                const initial = displayName.charAt(0).toUpperCase();

                // --- Desktop ---
                if (unauthDesktop) {
                    unauthDesktop.classList.remove('flex');
                    unauthDesktop.classList.add('hidden');
                }
                if (authDesktop) {
                    authDesktop.classList.remove('hidden');
                    authDesktop.classList.add('flex');
                    
                    const avatarEl = document.getElementById('user-avatar-desktop');
                    const initialsContainerEl = document.getElementById('user-initials-desktop');
                    const initialTextEl = document.getElementById('user-initial-text');

                    if (sessionData.user.image) {
                        if (avatarEl) {
                            avatarEl.setAttribute('src', sessionData.user.image);
                            avatarEl.classList.remove('hidden');
                        }
                        if (initialsContainerEl) {
                            initialsContainerEl.classList.remove('flex');
                            initialsContainerEl.classList.add('hidden');
                        }
                    } else {
                        if (avatarEl) avatarEl.classList.add('hidden');
                        if (initialsContainerEl) {
                            initialsContainerEl.classList.remove('hidden');
                            initialsContainerEl.classList.add('flex');
                        }
                        if (initialTextEl) initialTextEl.textContent = initial;
                    }
                }
                
                // --- Mobile ---
                if (unauthMobile) unauthMobile.classList.add('hidden');
                if (authMobile) {
                    authMobile.classList.remove('hidden');
                    
                    const nameEl = document.getElementById('user-name-mobile');
                    const avatarEl = document.getElementById('user-avatar-mobile');
                    const initialsContainerEl = document.getElementById('user-initials-mobile');
                    const initialTextEl = document.getElementById('user-initial-text-mobile');
                    
                    if (nameEl) nameEl.textContent = displayName;
                    
                    if (sessionData.user.image) {
                        if (avatarEl) {
                            avatarEl.setAttribute('src', sessionData.user.image);
                            avatarEl.classList.remove('hidden');
                        }
                        if (initialsContainerEl) {
                            initialsContainerEl.classList.remove('flex');
                            initialsContainerEl.classList.add('hidden');
                        }
                    } else {
                        if (avatarEl) avatarEl.classList.add('hidden');
                        if (initialsContainerEl) {
                            initialsContainerEl.classList.remove('hidden');
                            initialsContainerEl.classList.add('flex');
                        }
                        if (initialTextEl) initialTextEl.textContent = initial;
                    }
                }
            } else {
                // Not logged in
                if (authDesktop) {
                    authDesktop.classList.remove('flex');
                    authDesktop.classList.add('hidden');
                }
                if (unauthDesktop) {
                    unauthDesktop.classList.remove('hidden');
                    unauthDesktop.classList.add('flex');
                }
                
                if (authMobile) authMobile.classList.add('hidden');
                if (unauthMobile) {
                    unauthMobile.classList.remove('hidden');
                }
            }
        } catch (e) {
            console.error('Failed to get session:', e);
            // Show unauth state on error
            document.getElementById('auth-desktop')?.classList.remove('flex');
            document.getElementById('auth-desktop')?.classList.add('hidden');
            
            document.getElementById('unauth-desktop')?.classList.remove('hidden');
            document.getElementById('unauth-desktop')?.classList.add('flex');
            
            document.getElementById('auth-mobile')?.classList.add('hidden');
            document.getElementById('unauth-mobile')?.classList.remove('hidden');
        }
    }

    checkAuth();

    document.getElementById('logout-btn-desktop')?.addEventListener('click', async () => {
        await authClient.signOut();
        window.location.reload();
    });
    
    document.getElementById('logout-btn-mobile')?.addEventListener('click', async () => {
        await authClient.signOut();
        window.location.reload();
    });
</script>
