---
export interface Props {
    repo: any;
    repoIssues?: any[];
}
const { repo, repoIssues = [] } = Astro.props;

let diffCategory = 'all';
if (repo.health_score != null) {
    if (repo.health_score >= 75) diffCategory = 'easy';
    else if (repo.health_score >= 50) diffCategory = 'medium';
    else if (repo.health_score >= 25) diffCategory = 'hard';
    else diffCategory = 'very-hard';
}
---
<div data-type="repo" data-name={repo.name.toLowerCase()} data-lang={repo.language} data-difficulty={diffCategory} class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-green-500 hover:shadow-md transition-shadow flex flex-col overflow-hidden">
    <div class="p-5 flex-grow">
        <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2 truncate">
                <button type="button" class="bookmark-btn flex-shrink-0 text-gray-300 hover:text-indigo-500 dark:text-gray-600 dark:hover:text-amber-400 focus:outline-none transition-colors" data-repo-id={repo.full_name} title="Bookmark Repository">
                    <svg class="w-5 h-5 bookmark-icon-outline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
                    <svg class="w-5 h-5 bookmark-icon-solid hidden text-indigo-500 dark:text-amber-400" fill="currentColor" viewBox="0 0 24 24"><path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
                </button>
                <button type="button" class="repo-favourite-btn flex-shrink-0 text-gray-400 hover:text-red-500 dark:text-gray-500 dark:hover:text-red-400 focus:outline-none transition-colors" data-repo-id={repo.full_name} title="Add to Favourites">
                    <svg class="w-5 h-5 favourite-icon-outline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                    </svg>
                    <svg class="w-5 h-5 favourite-icon-solid hidden text-red-500 dark:text-red-400" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                    </svg>
                </button>
                <a href={`/repo/${repo.full_name}`} class="text-lg font-semibold text-gray-900 dark:text-gray-100 truncate hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">{repo.name}</a>
            </div>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 dark:bg-indigo-900/40 text-indigo-800 dark:text-indigo-300 ml-2">
                {repo.language}
            </span>
        </div>
        <div class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 mb-4 flex flex-col sm:flex-row sm:items-center justify-between gap-1 sm:gap-4">
            <span class="truncate">{repo.full_name}</span>
            {repo.last_active && (
                <span class="text-xs px-2 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 whitespace-nowrap self-start sm:self-auto" title="Last Active">
                    Active: {new Date(repo.last_active).toLocaleDateString()}
                </span>
            )}
        </div>
        <div class="flex flex-wrap items-center gap-2 sm:gap-4 text-xs sm:text-sm text-gray-600 dark:text-gray-400 mt-2">
            <span class="flex items-center gap-1" title="Stars">
                <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                {repo.stars.toLocaleString()}
            </span>
            <span class="flex items-center gap-1" title="Forks">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
                {repo.forks.toLocaleString()}
            </span>
            {repo.health_score != null && (
                <span class={`ml-auto text-[10px] sm:text-xs font-semibold px-2 py-0.5 rounded-full ${repo.health_score >= 75 ? 'bg-green-100 text-green-800' : repo.health_score >= 50 ? 'bg-yellow-100 text-yellow-800' : 'bg-red-100 text-red-800'}`}>
                    Difficulty: {repo.health_score >= 75 ? 'Easy' : repo.health_score >= 50 ? 'Medium' : repo.health_score >= 25 ? 'Hard' : 'Very Hard'}
                </span>
            )}
        </div>
    </div>
    <div class="bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-700 w-full mt-auto">
        <details class="group">
            <summary class="p-4 flex items-center justify-between cursor-pointer w-full text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors list-none outline-none">
                <span>View Active Issues ({repoIssues ? repoIssues.length : 0})</span>
                <span class="transition-transform group-open:rotate-180">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </span>
            </summary>
            
            <div class="p-4 pt-0 space-y-3 max-h-60 overflow-y-auto custom-scrollbar bg-gray-50 dark:bg-gray-800/50">
                {repoIssues && repoIssues.length > 0 ? (
                    repoIssues.map((issue: any) => {
                        const parts = issue.url.split('/');
                        const issueNum = parts[parts.length - 1];
                        return (
                        <div class="p-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm">
                            <a href={`/issue/${repo.full_name}/${issueNum}`} class="text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 hover:underline block truncate mb-1" title={issue.title}>
                                {issue.title}
                            </a>
                            <div class="flex items-center justify-between">
                                <span class="text-xs text-gray-500 dark:text-gray-400">
                                    {new Date(issue.created_at).toLocaleDateString()}
                                </span>
                                {issue.difficulty_score != null && (
                                    <span class={`text-[10px] uppercase tracking-wider font-semibold px-1.5 py-0.5 rounded ${
                                        issue.difficulty_score <= 25 ? 'bg-green-100 text-green-800' : 
                                        issue.difficulty_score <= 50 ? 'bg-yellow-100 text-yellow-800' : 
                                        issue.difficulty_score <= 75 ? 'bg-orange-100 text-orange-800' : 
                                        'bg-red-100 text-red-800'
                                    }`}>
                                        {issue.difficulty_score <= 25 ? 'Easy' : issue.difficulty_score <= 50 ? 'Medium' : issue.difficulty_score <= 75 ? 'Hard' : 'Very Hard'}
                                    </span>
                                )}
                            </div>
                        </div>
                        );
                    })
                ) : (
                    <p class="text-sm text-gray-500 italic pb-2">No active issues found for this repository.</p>
                )}
            </div>
        </details>
    </div>
</div>
<!-- Custom style to hide the default summary marker in Safari/Firefox -->
<style>
    details > summary::-webkit-details-marker {
        display: none;
    }
</style>

<script>
    import { getUserState, resetUserState } from '../lib/user-store';

    function toggleIcon(outline: Element, solid: Element, active: boolean) {
        outline.classList.toggle('hidden', active);
        solid.classList.toggle('hidden', !active);
    }

    function revertIcon(outline: Element, solid: Element, wasActive: boolean) {
        toggleIcon(outline, solid, wasActive);
    }

    async function postApi(url: string, body: object) {
        const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
        });
        if (res.status === 401) { window.location.href = '/login'; return null; }
        if (!res.ok) throw new Error('API error');
        return res.json();
    }

    async function initRepoCards() {
        const store = await getUserState();
        if (!store.loggedIn) {
            // Attach handlers for unauthenticated users
            document.querySelectorAll('.bookmark-btn, .repo-favourite-btn').forEach(btn => {
                if (!btn.hasAttribute('data-unauth-listener')) {
                    btn.setAttribute('data-unauth-listener', 'true');
                    btn.addEventListener('click', (e) => {
                        e.preventDefault(); e.stopPropagation();
                        if (typeof window.showAuthToast === 'function') window.showAuthToast();
                    });
                }
            });
            return;
        }

        // ── Bookmark buttons ──────────────────────────────────────
        document.querySelectorAll('.bookmark-btn').forEach(btn => {
            const repoId = btn.getAttribute('data-repo-id');
            if (!repoId) return;
            const outline = btn.querySelector('.bookmark-icon-outline')!;
            const solid   = btn.querySelector('.bookmark-icon-solid')!;
            if (!outline || !solid) return;

            toggleIcon(outline, solid, store.repoBookmarks.has(repoId));

            if (!btn.hasAttribute('data-bk-listener')) {
                btn.setAttribute('data-bk-listener', 'true');
                btn.addEventListener('click', async (e) => {
                    e.preventDefault(); e.stopPropagation();
                    const was = store.repoBookmarks.has(repoId);
                    toggleIcon(outline, solid, !was);
                    try {
                        const data = await postApi('/api/bookmarks', { repo_id: repoId });
                        if (data) {
                            data.bookmarked ? store.repoBookmarks.add(repoId) : store.repoBookmarks.delete(repoId);
                            toggleIcon(outline, solid, store.repoBookmarks.has(repoId));
                        }
                    } catch { revertIcon(outline, solid, !was); }
                });
            }
        });

        // ── Favourite buttons ─────────────────────────────────────
        document.querySelectorAll('.repo-favourite-btn').forEach(btn => {
            const repoId = btn.getAttribute('data-repo-id');
            if (!repoId) return;
            const outline = btn.querySelector('.favourite-icon-outline')!;
            const solid   = btn.querySelector('.favourite-icon-solid')!;
            if (!outline || !solid) return;

            toggleIcon(outline, solid, store.repoFavourites.has(repoId));

            if (!btn.hasAttribute('data-fav-listener')) {
                btn.setAttribute('data-fav-listener', 'true');
                btn.addEventListener('click', async (e) => {
                    e.preventDefault(); e.stopPropagation();
                    const was = store.repoFavourites.has(repoId);
                    toggleIcon(outline, solid, !was);
                    try {
                        const data = await postApi('/api/favourites', { repo_id: repoId });
                        if (data) {
                            data.favourited ? store.repoFavourites.add(repoId) : store.repoFavourites.delete(repoId);
                            toggleIcon(outline, solid, store.repoFavourites.has(repoId));
                        }
                    } catch { revertIcon(outline, solid, !was); }
                });
            }
        });
    }

    initRepoCards();
    document.addEventListener('astro:page-load', () => { resetUserState(); initRepoCards(); });
</script>
