---
import Layout from '../layouts/Layout.astro';
import { auth } from '../lib/auth';
import { pool } from '../lib/db';

export const prerender = false;

// Authenticate user
const sessionResponse = await auth.api.getSession({
    headers: Astro.request.headers
});

if (!sessionResponse || !sessionResponse.user) {
    return Astro.redirect('/login');
}

// Check if user has linked GitHub account
const client = await pool.connect();
let hasGithub = false;
try {
    const accountRes = await client.query(
        'SELECT "accountId" FROM "account" WHERE "userId" = $1 AND "providerId" = $2',
        [sessionResponse.user.id, 'github']
    );
    if (accountRes.rows.length > 0) {
        hasGithub = true;
    }
} finally {
    client.release();
}
---

<Layout title="Submit PR - Repo Wave" description="Submit your GitHub Pull Requests to earn contribution score.">
    <main class="max-w-3xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
        <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6 md:p-10">
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Submit PR Contribution</h1>
            <p class="text-gray-600 dark:text-gray-300 mb-8">
                Submit a merged Pull Request URL to calculate your contribution score.
            </p>

            {hasGithub ? (
                <form id="pr-submit-form" class="space-y-6">
                    <div>
                        <label for="pr_url" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                            GitHub Pull Request URL
                        </label>
                        <div class="mt-1">
                            <input
                                type="url"
                                name="pr_url"
                                id="pr_url"
                                required
                                placeholder="https://github.com/owner/repo/pull/123"
                                class="shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-md p-3"
                            />
                        </div>
                        <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
                            The PR must be merged and authored by your linked GitHub account.
                        </p>
                    </div>

                    <div id="error-message" class="hidden rounded-md bg-red-50 dark:bg-red-900/30 p-4">
                        <div class="flex">
                            <div class="ml-3">
                                <h3 class="text-sm font-medium text-red-800 dark:text-red-200" id="error-text"></h3>
                            </div>
                        </div>
                    </div>

                    <div id="success-message" class="hidden rounded-md bg-green-50 dark:bg-green-900/30 p-4">
                        <div class="flex">
                            <div class="ml-3">
                                <h3 class="text-sm font-medium text-green-800 dark:text-green-200">
                                    PR successfully submitted!
                                </h3>
                                <div class="mt-2 text-sm text-green-700 dark:text-green-300" id="success-text"></div>
                                <div class="mt-4">
                                    <a href={`/${sessionResponse.user.username}`} class="text-green-800 dark:text-green-200 underline font-medium">
                                        View in your profile
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div>
                        <button
                            type="submit"
                            id="submit-btn"
                            class="w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
                        >
                            Validate & Score PR
                        </button>
                    </div>
                </form>
            ) : (
                <div class="bg-yellow-50 dark:bg-yellow-900/30 border-l-4 border-yellow-400 p-4">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="ml-3">
                            <h3 class="text-sm font-medium text-yellow-800 dark:text-yellow-200">
                                GitHub Account Required
                            </h3>
                            <div class="mt-2 text-sm text-yellow-700 dark:text-yellow-300">
                                <p>
                                    You need to connect your GitHub account to verify your Pull Requests. 
                                    If you signed up with Google or Email, please link your GitHub account first.
                                </p>
                            </div>
                            <div class="mt-4">
                                <button id="link-github-btn" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-gray-800 hover:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900">
                                    <svg class="mr-2 h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                                    </svg>
                                    Link GitHub Account
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            )}
        </div>
    </main>
</Layout>

<script>
    import { authClient } from '../lib/auth-client';

    const form = document.getElementById('pr-submit-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const errorMsg = document.getElementById('error-message');
    const errorText = document.getElementById('error-text');
    const successMsg = document.getElementById('success-message');
    const successText = document.getElementById('success-text');
    const linkGithubBtn = document.getElementById('link-github-btn');

    if (linkGithubBtn) {
        linkGithubBtn.addEventListener('click', async () => {
            await authClient.signIn.social({
                provider: 'github',
                callbackURL: '/submit-pr'
            });
        });
    }

    if (form) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.textContent = 'Validating...';
            }
            if (errorMsg) errorMsg.classList.add('hidden');
            if (successMsg) successMsg.classList.add('hidden');

            const formData = new FormData(form);
            const prUrl = formData.get('pr_url');

            try {
                const response = await fetch('/api/pr/validate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ pr_url: prUrl })
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.error || 'Failed to submit PR');
                }

                if (successMsg && successText) {
                    successMsg.classList.remove('hidden');
                    successText.innerHTML = `
                        <p>Score: <strong>${data.score}</strong></p>
                        <p class="mt-1 text-xs">Factors: Impact (${data.stats.impact}x), Quality (${data.stats.quality}x), Difficulty (${data.stats.difficulty}x), Time (${data.stats.timeBonus}x)</p>
                    `;
                }
                form.reset();
            } catch (err: any) {
                if (errorMsg && errorText) {
                    errorMsg.classList.remove('hidden');
                    errorText.textContent = err.message;
                }
            } finally {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Validate & Score PR';
                }
            }
        });
    }
</script>
