---
import Layout from '../../layouts/Layout.astro';
import { pool } from '../../lib/db';

export const prerender = false;

const { id } = Astro.params;

if (!id) {
    return Astro.redirect('/404');
}

// Fetch PR Contribution
let pr = null;
let user = null;
try {
    const prRes = await pool.query(
        'SELECT * FROM public.pr_contributions WHERE id = $1',
        [id]
    );
    if (prRes.rows.length > 0) {
        pr = prRes.rows[0];
        
        // Fetch user info
        const userRes = await pool.query(
            'SELECT username, name, image FROM "user" WHERE id = $1',
            [pr.user_id]
        );
        if (userRes.rows.length > 0) {
            user = userRes.rows[0];
        }
    }
} catch (e) {
    console.error("Error fetching PR", e);
}

if (!pr || !user) {
    return Astro.redirect('/404');
}

const displayName = user.name || user.username;
const mergedDate = new Date(pr.pr_merged_at).toLocaleDateString(undefined, {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
});
---

<Layout title={`PR: ${pr.pr_title} | Repo Wave`} description={`Contribution by ${displayName}`}>
    <main class="max-w-4xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
        <div class="mb-6">
            <a href={`/${user.username}`} class="text-blue-600 hover:underline flex items-center gap-1 text-sm font-medium">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Back to {displayName}'s Profile
            </a>
        </div>

        <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 overflow-hidden">
            <!-- Header -->
            <div class="border-b border-gray-200 dark:border-gray-800 p-6 md:p-8 bg-gray-50 dark:bg-gray-800/50">
                <div class="flex flex-col md:flex-row md:items-start justify-between gap-6">
                    <div>
                        <div class="flex items-center gap-2 mb-3">
                            <span class="px-3 py-1 bg-purple-100 text-purple-800 dark:bg-purple-900/50 dark:text-purple-300 rounded-full text-xs font-semibold uppercase tracking-wide">
                                Merged PR
                            </span>
                            <span class="text-gray-500 dark:text-gray-400 text-sm">
                                {mergedDate}
                            </span>
                        </div>
                        <h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-2">
                            {pr.pr_title}
                        </h1>
                        <a href={pr.pr_url} target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-blue-400 hover:underline flex items-center gap-1 font-medium">
                            View on GitHub
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                        </a>
                    </div>
                    
                    <div class="flex-shrink-0 bg-white dark:bg-gray-800 rounded-xl p-4 shadow-sm border border-gray-100 dark:border-gray-700 text-center min-w-[120px]">
                        <div class="text-sm text-gray-500 dark:text-gray-400 font-semibold uppercase tracking-wider mb-1">Total Score</div>
                        <div class="text-4xl font-black text-blue-600 dark:text-blue-400">
                            {parseFloat(pr.score).toFixed(1)}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Content -->
            <div class="p-6 md:p-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <!-- Repository Info -->
                    <div>
                        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
                            <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M2 6a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1H8a3 3 0 00-3 3v7H4a2 2 0 01-2-2V6zm14 3H8a1 1 0 00-1 1v9a1 1 0 001 1h12a1 1 0 001-1v-8a1 1 0 00-1-1h-4l-2-2z" clip-rule="evenodd"></path></svg>
                            Repository
                        </h3>
                        <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-4">
                            <div class="font-mono text-gray-900 dark:text-white text-lg mb-2">{pr.repo_name}</div>
                            <div class="flex items-center gap-2 text-gray-600 dark:text-gray-300">
                                <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                                <span class="font-medium">{pr.repo_stars.toLocaleString()}</span> stars
                            </div>
                        </div>
                    </div>

                    <!-- Contributor Info -->
                    <div>
                        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
                            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            Contributor
                        </h3>
                        <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-4 flex items-center gap-4">
                            {user.image ? (
                                <img src={user.image} alt={displayName} class="h-12 w-12 rounded-full object-cover" />
                            ) : (
                                <div class="h-12 w-12 rounded-full bg-indigo-500 text-white flex items-center justify-center text-xl font-bold">
                                    {displayName.charAt(0).toUpperCase()}
                                </div>
                            )}
                            <div>
                                <div class="font-bold text-gray-900 dark:text-white">{user.name}</div>
                                <a href={`/${user.username}`} class="text-gray-500 dark:text-gray-400 hover:text-blue-600">@{user.username}</a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Stats Grid -->
                <div class="mt-10">
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4 border-b border-gray-200 dark:border-gray-700 pb-2">
                        Contribution Metrics
                    </h3>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        <div class="bg-gray-50 dark:bg-gray-800/50 p-4 rounded-lg border border-gray-100 dark:border-gray-800">
                            <div class="text-sm text-gray-500 dark:text-gray-400 mb-1">Code Additions</div>
                            <div class="text-xl font-semibold text-green-600">+{pr.additions}</div>
                        </div>
                        <div class="bg-gray-50 dark:bg-gray-800/50 p-4 rounded-lg border border-gray-100 dark:border-gray-800">
                            <div class="text-sm text-gray-500 dark:text-gray-400 mb-1">Code Deletions</div>
                            <div class="text-xl font-semibold text-red-600">-{pr.deletions}</div>
                        </div>
                        <div class="bg-gray-50 dark:bg-gray-800/50 p-4 rounded-lg border border-gray-100 dark:border-gray-800">
                            <div class="text-sm text-gray-500 dark:text-gray-400 mb-1">Total Comments</div>
                            <div class="text-xl font-semibold text-gray-900 dark:text-white">{pr.comments}</div>
                        </div>
                        <div class="bg-gray-50 dark:bg-gray-800/50 p-4 rounded-lg border border-gray-100 dark:border-gray-800">
                            <div class="text-sm text-gray-500 dark:text-gray-400 mb-1">Review Comments</div>
                            <div class="text-xl font-semibold text-gray-900 dark:text-white">{pr.review_comments}</div>
                        </div>
                    </div>
                </div>
                
                <!-- Formula Info -->
                <div class="mt-8 bg-blue-50 dark:bg-blue-900/20 rounded-lg p-4 border border-blue-100 dark:border-blue-800/50">
                    <h4 class="text-sm font-semibold text-blue-800 dark:text-blue-300 mb-2 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Scoring Formula
                    </h4>
                    <p class="text-sm text-blue-700 dark:text-blue-400">
                        Score = Base(1) × Impact (Stars) × Quality (Reviews/Comments) × Difficulty (Lines Changed) × Time Bonus
                    </p>
                </div>

            </div>
        </div>
    </main>
</Layout>
