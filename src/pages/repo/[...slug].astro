---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';
import { fetchAllRecords } from '../../lib/fetchAll';

export async function getStaticPaths() {
    const repos = await fetchAllRecords('repos', '*', 'stars', false, 5000);
    return repos.map((repo: any) => ({
        params: { slug: repo.full_name },
        props: { repo }
    }));
}

const { repo } = Astro.props;

const { data: repoIssues } = await supabase
    .from('issues')
    .select('*')
    .eq('repo_id', repo.full_name)
    .order('created_at', { ascending: false })
    .limit(200);

// Difficulty helpers — kept in frontmatter to avoid Astro compiler issues with <= in templates
let diffCategory = 'Unknown';
if (repo.health_score != null) {
    if (repo.health_score >= 75) diffCategory = 'Easy';
    else if (repo.health_score >= 50) diffCategory = 'Medium';
    else if (repo.health_score >= 25) diffCategory = 'Hard';
    else diffCategory = 'Very Hard';
}

function getIssueDifficulty(score: number | null) {
    if (score == null) return 'Unknown';
    if (score <= 25) return 'Easy';
    if (score <= 50) return 'Medium';
    if (score <= 75) return 'Hard';
    return 'Very Hard';
}

function getDiffClass(dc: string) {
    if (dc === 'Easy') return 'bg-green-100 text-green-800';
    if (dc === 'Medium') return 'bg-yellow-100 text-yellow-800';
    if (dc === 'Hard') return 'bg-orange-100 text-orange-800';
    return 'bg-red-100 text-red-800';
}

const diffBadgeClass =
    diffCategory === 'Easy' ? 'bg-green-100 text-green-800' :
    diffCategory === 'Medium' ? 'bg-yellow-100 text-yellow-800' :
    diffCategory === 'Hard' ? 'bg-orange-100 text-orange-800' :
    'bg-red-100 text-red-800';

const processedIssues = (repoIssues || []).map((issue: any) => {
    const parts = issue.url.split('/');
    const number = parts[parts.length - 1];
    const rawLabels = Array.isArray(issue.labels?.tags) ? issue.labels.tags
        : (Array.isArray(issue.labels) ? issue.labels : []);
    const dc = getIssueDifficulty(issue.difficulty_score);
    return {
        ...issue,
        issueSlug: `${issue.repo_id}/${number}`,
        issueNumber: number,
        processedLabels: rawLabels.map((l: any) => typeof l === 'string' ? l : l.name || '').filter(Boolean),
        dc,
        dcClass: getDiffClass(dc),
        formattedDate: new Date(issue.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
    };
});

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://opensourcefinder.com';
const githubUrl = `https://github.com/${repo.full_name}`;

const repoJsonLd = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareSourceCode",
    "name": repo.name,
    "alternateName": repo.full_name,
    "url": `${siteUrl}/repo/${repo.full_name}`,
    "codeRepository": githubUrl,
    "programmingLanguage": repo.language || "Unknown",
    "description": `Open-source ${repo.language || ''} repository ${repo.full_name} with ${repo.stars?.toLocaleString() || 0} stars and ${repo.forks?.toLocaleString() || 0} forks. Difficulty: ${diffCategory}.`,
    "author": { "@type": "Organization", "name": repo.full_name.split('/')[0] },
    "dateModified": repo.last_active || undefined
});

const pageTitle = `${repo.name} — ${repo.language || 'Open Source'} Repository | Open Source Finder`;
const pageDesc = `Explore ${repo.full_name}: a ${repo.language || 'open-source'} repo with ${repo.stars?.toLocaleString()} stars, ${repo.forks?.toLocaleString()} forks, and ${processedIssues.length} beginner-friendly issues. Difficulty: ${diffCategory}.`;
---

<Layout title={pageTitle} description={pageDesc} jsonLd={repoJsonLd}>
    <!-- Hero Banner -->
    <div class="bg-gradient-to-br from-indigo-900 via-indigo-800 to-purple-900 text-white">
        <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
            <!-- Breadcrumb -->
            <nav class="mb-5 text-sm text-indigo-300" aria-label="Breadcrumb">
                <ol class="flex items-center gap-1.5 flex-wrap">
                    <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
                    <li class="text-indigo-500">/</li>
                    <li><a href="/repositories" class="hover:text-white transition-colors">Repositories</a></li>
                    <li class="text-indigo-500">/</li>
                    <li class="text-white font-medium truncate max-w-[200px]">{repo.name}</li>
                </ol>
            </nav>

            <!-- Repo Title Row -->
            <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
                <div class="min-w-0">
                    <div class="flex items-center gap-3 flex-wrap mb-2">
                        <h1 class="text-3xl sm:text-4xl font-bold text-white break-words">{repo.name}</h1>
                        {repo.language && (
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-white/10 text-indigo-200 border border-white/20">
                                {repo.language}
                            </span>
                        )}
                        <span class={`inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold ${diffBadgeClass}`}>
                            {diffCategory}
                        </span>
                    </div>
                    <p class="text-indigo-300 text-sm sm:text-base">{repo.full_name}</p>
                </div>
                <a
                    href={githubUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-gray-900 rounded-xl text-sm font-semibold hover:bg-indigo-50 transition-colors whitespace-nowrap flex-shrink-0 shadow-lg"
                >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                    </svg>
                    View on GitHub
                </a>
            </div>

            <!-- Stats Bar -->
            <div class="flex flex-wrap items-center gap-4 sm:gap-8 mt-6 text-sm">
                <div class="flex items-center gap-2 text-indigo-200">
                    <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    <span class="font-semibold text-white">{repo.stars?.toLocaleString()}</span> stars
                </div>
                <div class="flex items-center gap-2 text-indigo-200">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
                    <span class="font-semibold text-white">{repo.forks?.toLocaleString()}</span> forks
                </div>
                <div class="flex items-center gap-2 text-indigo-200">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                    <span class="font-semibold text-white">{processedIssues.length}</span> open issues
                </div>
                {repo.last_active && (
                    <div class="flex items-center gap-2 text-indigo-200">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Active {new Date(repo.last_active).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                    </div>
                )}
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col lg:flex-row gap-8">

            <!-- LEFT: Sidebar Info Panel -->
            <aside class="w-full lg:w-80 xl:w-96 flex-shrink-0 space-y-5">

                <!-- Health Metrics -->
                {repo.health_json && (
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5">
                        <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider mb-4">Repository Health</h2>
                        <div class="space-y-3">
                            {repo.health_json.commits_30d != null && (
                                <div class="flex items-center justify-between">
                                    <span class="text-sm text-gray-500 flex items-center gap-2">
                                        <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                                        Commits (30d)
                                    </span>
                                    <span class="text-sm font-bold text-gray-900">{repo.health_json.commits_30d}</span>
                                </div>
                            )}
                            {repo.health_json.pr_merge_avg_hrs != null && (
                                <div class="flex items-center justify-between">
                                    <span class="text-sm text-gray-500 flex items-center gap-2">
                                        <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
                                        Avg PR Merge
                                    </span>
                                    <span class="text-sm font-bold text-gray-900">{Math.round(repo.health_json.pr_merge_avg_hrs)}h</span>
                                </div>
                            )}
                            {repo.health_json.response_time_avg_hrs != null && (
                                <div class="flex items-center justify-between">
                                    <span class="text-sm text-gray-500 flex items-center gap-2">
                                        <svg class="w-4 h-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                                        Avg Response
                                    </span>
                                    <span class="text-sm font-bold text-gray-900">{Math.round(repo.health_json.response_time_avg_hrs)}h</span>
                                </div>
                            )}
                            {repo.health_json.success_indicators?.total_recent_merged_prs != null && (
                                <div class="flex items-center justify-between">
                                    <span class="text-sm text-gray-500 flex items-center gap-2">
                                        <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                        Recent Merged PRs
                                    </span>
                                    <span class="text-sm font-bold text-gray-900">{repo.health_json.success_indicators.total_recent_merged_prs}</span>
                                </div>
                            )}
                            {repo.health_json.success_indicators?.quick_wins_count != null && (
                                <div class="flex items-center justify-between">
                                    <span class="text-sm text-gray-500 flex items-center gap-2">
                                        <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                                        Quick Wins
                                    </span>
                                    <span class="text-sm font-bold text-gray-900">{repo.health_json.success_indicators.quick_wins_count}</span>
                                </div>
                            )}
                        </div>

                        <!-- Health Score Bar -->
                        {repo.health_score != null && (
                            <div class="mt-4 pt-4 border-t border-gray-100">
                                <div class="flex items-center justify-between mb-1.5">
                                    <span class="text-xs text-gray-500">Health Score</span>
                                    <span class="text-xs font-bold text-gray-700">{Math.round(repo.health_score)}/100</span>
                                </div>
                                <div class="w-full bg-gray-100 rounded-full h-2">
                                    <div
                                        class={`h-2 rounded-full ${repo.health_score >= 75 ? 'bg-green-500' : repo.health_score >= 50 ? 'bg-yellow-500' : 'bg-red-500'}`}
                                        style={`width: ${Math.min(100, repo.health_score)}%`}
                                    ></div>
                                </div>
                            </div>
                        )}
                    </div>
                )}

                <!-- Maintainer Info -->
                {repo.health_json?.maintainer_quality && (
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5">
                        <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider mb-4">Maintainer Quality</h2>
                        <div class="space-y-2">
                            <div class="flex items-center gap-2">
                                <span class={`w-2 h-2 rounded-full ${repo.health_json.maintainer_quality.has_codeowners ? 'bg-green-500' : 'bg-gray-300'}`}></span>
                                <span class="text-sm text-gray-600">Has CODEOWNERS</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class={`w-2 h-2 rounded-full ${!repo.health_json.maintainer_quality.solo_maintainer ? 'bg-green-500' : 'bg-yellow-500'}`}></span>
                                <span class="text-sm text-gray-600">{repo.health_json.maintainer_quality.solo_maintainer ? 'Solo maintainer' : 'Multiple maintainers'}</span>
                            </div>
                            {repo.health_json.maintainer_quality.response_24h_rate != null && (
                                <div class="flex items-center justify-between">
                                    <span class="text-sm text-gray-500">24h response rate</span>
                                    <span class="text-sm font-bold text-gray-900">{Math.min(100, Math.round(repo.health_json.maintainer_quality.response_24h_rate * 100))}%</span>
                                </div>
                            )}
                        </div>
                    </div>
                )}

                <!-- Quick Links -->
                <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5">
                    <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider mb-4">Quick Links</h2>
                    <div class="space-y-2">
                        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-2.5 rounded-lg hover:bg-gray-50 text-sm text-gray-700 hover:text-indigo-600 transition-colors">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
                            Repository
                        </a>
                        <a href={`${githubUrl}/issues`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-2.5 rounded-lg hover:bg-gray-50 text-sm text-gray-700 hover:text-indigo-600 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                            All GitHub Issues
                        </a>
                        <a href={`${githubUrl}/pulls`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-2.5 rounded-lg hover:bg-gray-50 text-sm text-gray-700 hover:text-indigo-600 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
                            Pull Requests
                        </a>
                        <a href="/repositories" class="flex items-center gap-3 p-2.5 rounded-lg hover:bg-gray-50 text-sm text-gray-700 hover:text-indigo-600 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                            All Repositories
                        </a>
                    </div>
                </div>
            </aside>

            <!-- RIGHT: Issues Panel (main content, takes remaining width) -->
            <main class="flex-1 min-w-0">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
                    <div class="p-5 sm:p-6 border-b border-gray-100 flex items-center justify-between gap-4 flex-wrap">
                        <div>
                            <h2 class="text-xl font-bold text-gray-900 flex items-center gap-2">
                                Beginner-Friendly Issues
                                <span class="text-sm font-normal text-gray-500 bg-gray-100 px-2.5 py-0.5 rounded-full">
                                    {processedIssues.length}
                                </span>
                            </h2>
                            <p class="text-sm text-gray-500 mt-0.5">Issues tagged for new contributors</p>
                        </div>
                        <a href={`${githubUrl}/issues?q=is%3Aopen+label%3A%22good+first+issue%22`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs font-medium text-indigo-600 hover:text-indigo-800 transition-colors">
                            View all on GitHub
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                        </a>
                    </div>

                    {processedIssues.length > 0 ? (
                        <div class="divide-y divide-gray-100">
                            {processedIssues.map((pi: any) => (
                                <div class="p-4 sm:p-5 hover:bg-gray-50 transition-colors group">
                                    <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-2 sm:gap-4">
                                        <div class="min-w-0 flex-1">
                                            <a href={`/issue/${pi.issueSlug}`} class="text-sm sm:text-base font-medium text-indigo-600 hover:text-indigo-800 hover:underline break-words leading-snug group-hover:text-indigo-800">
                                                {pi.title}
                                            </a>
                                            <div class="flex items-center gap-2 mt-1.5 text-xs text-gray-400">
                                                <span>#{pi.issueNumber}</span>
                                                <span>·</span>
                                                <span>{pi.formattedDate}</span>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-2 flex-shrink-0 flex-wrap">
                                            {pi.difficulty_score != null && (
                                                <span class={`text-xs font-semibold px-2.5 py-0.5 rounded-full whitespace-nowrap ${pi.dcClass}`}>
                                                    {pi.dc}
                                                </span>
                                            )}
                                            <a href={pi.url} target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-gray-500 transition-colors" title="View on GitHub" aria-label="View on GitHub">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                                            </a>
                                        </div>
                                    </div>
                                    {pi.processedLabels.length > 0 && (
                                        <div class="flex flex-wrap gap-1.5 mt-2">
                                            {pi.processedLabels.map((label: string) => (
                                                <span class="inline-flex items-center px-2 py-0.5 rounded text-[11px] font-medium bg-gray-100 text-gray-600">
                                                    {label}
                                                </span>
                                            ))}
                                        </div>
                                    )}
                                </div>
                            ))}
                        </div>
                    ) : (
                        <div class="flex flex-col items-center justify-center py-16 px-8 text-center">
