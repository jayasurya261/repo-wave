---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';
import { fetchAllRecords } from '../../lib/fetchAll';

export async function getStaticPaths() {
    const issues = await fetchAllRecords('issues', '*, repos(language, name, stars, forks, health_score)', 'created_at', false, 5000);
    return issues.map((issue: any) => {
        // Extract issue number from URL: https://github.com/owner/repo/issues/123
        const parts = issue.url.split('/');
        const number = parts[parts.length - 1];
        const slug = `${issue.repo_id}/${number}`;
        return {
            params: { slug },
            props: { 
                issue: {
                    ...issue,
                    language: issue.repos?.language || '',
                    repoName: issue.repos?.name || issue.repo_id.split('/').pop() || '',
                    repoStars: issue.repos?.stars || 0,
                    repoForks: issue.repos?.forks || 0,
                    issueNumber: number
                }
            }
        };
    });
}

const { issue } = Astro.props;
const labels: any[] = Array.isArray(issue.labels?.tags) ? issue.labels.tags : (Array.isArray(issue.labels) ? issue.labels : []);

let diffCategory = 'Unknown';
if (issue.difficulty_score != null) {
    if (issue.difficulty_score <= 25) diffCategory = 'Easy';
    else if (issue.difficulty_score <= 50) diffCategory = 'Medium';
    else if (issue.difficulty_score <= 75) diffCategory = 'Hard';
    else diffCategory = 'Very Hard';
}

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://opensourcefinder.com';

// JSON-LD structured data for this issue
const issueJsonLd = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": issue.title,
    "url": `${siteUrl}/issue/${issue.repo_id}/${issue.issueNumber}`,
    "datePublished": issue.created_at,
    "author": {
        "@type": "Organization",
        "name": issue.repo_id.split('/')[0]
    },
    "publisher": {
        "@type": "Organization",
        "name": "Open Source Finder",
        "url": siteUrl
    },
    "about": {
        "@type": "SoftwareSourceCode",
        "name": issue.repoName,
        "codeRepository": `https://github.com/${issue.repo_id}`,
        "programmingLanguage": issue.language || "Unknown"
    },
    "keywords": labels.map((l: any) => typeof l === 'string' ? l : l.name || '').filter(Boolean)
});

const pageTitle = `${issue.title} — ${issue.repo_id} #${issue.issueNumber} | Open Source Finder`;
const pageDesc = `${diffCategory} difficulty open-source issue in ${issue.repo_id} (${issue.language || 'open source'}). ${labels.length > 0 ? 'Labels: ' + labels.slice(0, 3).map((l: any) => typeof l === 'string' ? l : l.name || '').join(', ') + '.' : ''} Contribute to this beginner-friendly issue today.`;
---

<Layout title={pageTitle} description={pageDesc} jsonLd={issueJsonLd}>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

        <!-- Breadcrumb -->
        <nav class="mb-6 text-sm text-gray-500" aria-label="Breadcrumb">
            <ol class="flex items-center gap-1.5 flex-wrap">
                <li><a href="/" class="hover:text-indigo-600 transition-colors">Home</a></li>
                <li class="text-gray-300">/</li>
                <li><a href="/issues" class="hover:text-indigo-600 transition-colors">Issues</a></li>
                <li class="text-gray-300">/</li>
                <li><a href={`/repo/${issue.repo_id}`} class="hover:text-indigo-600 transition-colors truncate max-w-[120px]" title={issue.repo_id}>{issue.repoName}</a></li>
                <li class="text-gray-300">/</li>
                <li class="text-gray-700 font-medium">#{issue.issueNumber}</li>
            </ol>
        </nav>

        <!-- Issue Header -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8 mb-8">
            <div class="flex flex-col gap-4">
                <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
                    <div class="min-w-0 flex-1">
                        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 break-words leading-tight">{issue.title}</h1>
                        <div class="flex flex-wrap items-center gap-3 mt-3 text-sm text-gray-500">
                            <span class="inline-flex items-center gap-1">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                {new Date(issue.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                            </span>
                            <span class="text-gray-300">·</span>
                            <span class="font-medium text-gray-700">#{issue.issueNumber}</span>
                        </div>
                    </div>
                    <a 
                        href={issue.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 px-5 py-2.5 bg-gray-900 text-white rounded-lg text-sm font-medium hover:bg-gray-800 transition-colors whitespace-nowrap flex-shrink-0"
                    >
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                        </svg>
                        View on GitHub
                    </a>
                </div>

                <!-- Info Badges -->
                <div class="flex flex-wrap items-center gap-2 mt-2">
                    {issue.language && (
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                            {issue.language}
                        </span>
                    )}
                    {issue.difficulty_score != null && (
                        <span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold ${
                            diffCategory === 'Easy' ? 'bg-green-100 text-green-800' :
                            diffCategory === 'Medium' ? 'bg-yellow-100 text-yellow-800' :
                            diffCategory === 'Hard' ? 'bg-orange-100 text-orange-800' :
                            'bg-red-100 text-red-800'
                        }`}>
                            Difficulty: {diffCategory}
                        </span>
                    )}
                </div>

                <!-- Labels -->
                {labels.length > 0 && (
                    <div class="mt-4 pt-4 border-t border-gray-100">
                        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Labels</p>
                        <div class="flex flex-wrap gap-2">
                            {labels.map((label: any) => (
                                <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-gray-100 text-gray-700 border border-gray-200">
                                    {typeof label === 'string' ? label : label.name || ''}
                                </span>
                            ))}
                        </div>
                    </div>
                )}
            </div>
        </div>

        <!-- Parent Repository Card -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sm:p-8">
            <h2 class="text-lg font-bold text-gray-900 mb-4">Parent Repository</h2>
            <a href={`/repo/${issue.repo_id}`} class="block p-4 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors border border-gray-100">
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                    <div class="min-w-0">
                        <p class="text-base font-semibold text-indigo-600 hover:text-indigo-800">{issue.repo_id}</p>
                        {issue.language && (
                            <p class="text-xs text-gray-500 mt-0.5">{issue.language} repository</p>
                        )}
                    </div>
                    <div class="flex items-center gap-4 text-sm text-gray-600 flex-shrink-0">
                        {issue.repoStars > 0 && (
                            <span class="flex items-center gap-1">
                                <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                {issue.repoStars.toLocaleString()}
                            </span>
                        )}
                        {issue.repoForks > 0 && (
                            <span class="flex items-center gap-1">
                                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
                                {issue.repoForks.toLocaleString()}
                            </span>
                        )}
                        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </div>
                </div>
            </a>
        </div>

        <!-- Back Navigation -->
        <div class="mt-8 flex justify-center gap-6">
            <a href="/issues" class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-indigo-600 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                All Issues
            </a>
            <a href={`/repo/${issue.repo_id}`} class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-indigo-600 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Back to {issue.repoName}
            </a>
        </div>
    </div>
</Layout>
