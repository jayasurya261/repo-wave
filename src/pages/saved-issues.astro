---
import Layout from '../layouts/Layout.astro';
import IssueCard from '../components/IssueCard.astro';
import { supabase } from '../lib/supabase';
import { auth } from '../lib/auth';

export const prerender = false;

let session = null;
try {
    session = await auth.api.getSession({ headers: Astro.request.headers });
} catch (e) {}

if (!session?.user) return Astro.redirect('/login');

const userId = session.user.id;
let bookmarkedIssues: any[] = [];

try {
    const { data: bIssues } = await supabase
        .from('issue_bookmarks')
        .select('issue_id')
        .eq('user_id', userId);

    if (bIssues && bIssues.length > 0) {
        const issuePromises = bIssues.map(async b => {
            const parts = b.issue_id.split('/');
            const issueNum = parts.pop();
            const repoId = parts.join('/');
            const { data } = await supabase
                .from('issues')
                .select('*')
                .eq('repo_id', repoId)
                .like('url', `%/${issueNum}`)
                .limit(1)
                .single();
            return data;
        });
        const results = await Promise.all(issuePromises);
        bookmarkedIssues = results.filter(Boolean);
    }
} catch (error) {
    console.error('Error fetching saved issues:', error);
}
---

<Layout title="Saved Issues | Open Source Finder" description="Your bookmarked issues.">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 min-h-[70vh]">
        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div>
                <div class="flex items-center gap-3 mb-1">
                    <div class="p-2 bg-amber-100 dark:bg-amber-900/40 rounded-lg">
                        <svg class="w-6 h-6 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
                        </svg>
                    </div>
                    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Saved Issues</h1>
                </div>
                <p class="text-gray-500 dark:text-gray-400 ml-11">
                    {bookmarkedIssues.length} {bookmarkedIssues.length === 1 ? 'issue' : 'issues'} saved
                </p>
            </div>
            <a href="/saved-repos" class="inline-flex items-center gap-2 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline">
                View Saved Repos →
            </a>
        </div>

        {bookmarkedIssues.length > 0 ? (
            <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden divide-y divide-gray-100 dark:divide-gray-800">
                {bookmarkedIssues.map(issue => (
                    <IssueCard issue={issue} />
                ))}
            </div>
        ) : (
            <div class="text-center py-20 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
                <div class="mx-auto w-16 h-16 rounded-full bg-amber-50 dark:bg-amber-900/30 flex items-center justify-center mb-4">
                    <svg class="w-8 h-8 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
                    </svg>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">No saved issues yet</h3>
                <p class="text-gray-500 dark:text-gray-400 mb-6">Click the bookmark icon on any issue to save it here.</p>
                <a href="/issues" class="inline-flex items-center px-5 py-2.5 bg-amber-600 text-white text-sm font-medium rounded-lg hover:bg-amber-700 transition-colors">
                    Browse Issues
                </a>
            </div>
        )}
    </div>
</Layout>
