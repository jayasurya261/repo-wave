---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import SidebarFilter from '../components/SidebarFilter.astro';
import SearchBar from '../components/SearchBar.astro';
import RepoCard from '../components/RepoCard.astro';
import IssueCard from '../components/IssueCard.astro';
import { fetchAllRecords } from '../lib/fetchAll';

const PAGE_SIZE = 20;

let repos: any[] = [];
let issues: any[] = [];
let fetchFailed = false;

try {
	// Fetch only first page of repos for initial render
	repos = await fetchAllRecords('repos', '*', 'stars', false, PAGE_SIZE);
	const issuesRaw = await fetchAllRecords('issues', '*, repos(language)', 'created_at', false, PAGE_SIZE);
	issues = issuesRaw?.map((issue: any) => ({
		...issue,
		language: issue.repos?.language || ''
	})) ?? [];
} catch (err) {
	console.error('[index] Failed to fetch data from Supabase:', err);
	fetchFailed = true;
}

// Unique languages — fetched separately with a small query
let uniqueLanguages: string[] = [];
try {
	const langRows = await fetchAllRecords('repos', 'language', 'language', true, 5000);
	uniqueLanguages = [...new Set(langRows.map((r: any) => r.language).filter(Boolean))].sort() as string[];
} catch { /* non-fatal */ }

// Build issuesByRepo map from the already-fetched 20 issues
const issuesByRepo = new Map<string, any[]>();
for (const issue of issues) {
	const key = issue.repo_id;
	if (!issuesByRepo.has(key)) issuesByRepo.set(key, []);
	issuesByRepo.get(key)!.push(issue);
}

// Data freshness: most recently scraped issue timestamp
let lastUpdated: string | null = null;
try {
	const { supabase } = await import('../lib/supabase');
	const { data } = await supabase
		.from('issues')
		.select('created_at')
		.order('created_at', { ascending: false })
		.limit(1)
		.single();
	if (data?.created_at) {
		const diff = Date.now() - new Date(data.created_at).getTime();
		const h = Math.floor(diff / 36e5);
		const d = Math.floor(diff / 864e5);
		lastUpdated = d >= 1 ? `${d}d ago` : h >= 1 ? `${h}h ago` : 'just now';
	}
} catch { /* non-fatal */ }
---

<Layout title="Repo Wave Dashboard | Open Source Finder" description="Browse top open-source repositories and discover beginner-friendly issues to contribute to today.">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

		{fetchFailed && (
			<div class="flex items-start gap-3 bg-amber-50 border border-amber-300 text-amber-800 px-5 py-4 rounded-xl mb-8 shadow-sm">
				<svg class="flex-shrink-0 mt-0.5" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
					<line x1="12" y1="9" x2="12" y2="13"/>
					<line x1="12" y1="17" x2="12.01" y2="17"/>
				</svg>
				<div>
					<p class="font-semibold text-sm">Service temporarily unavailable</p>
					<p class="text-sm mt-0.5 text-amber-700">We couldn&apos;t load the latest data right now. Please try refreshing the page in a moment.</p>
				</div>
			</div>
		)}

		<!-- Main Layout with Sidebar and Content -->
		<div class="flex flex-col md:flex-row gap-8">
			
			<SidebarFilter uniqueLanguages={uniqueLanguages} />

			<!-- Main Content Area -->
			<main class="flex-grow min-w-0">
				
				<SearchBar />

				<!-- Issues Section -->
				<section class="mb-12">
					<h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2">
						Recent Issues
						<span id="issueCount" class="text-sm font-normal text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 px-2 py-0.5 rounded-full">{issues ? issues.length : 0}</span>
						{lastUpdated && (
							<span class="ml-auto text-xs font-normal text-gray-400 dark:text-gray-500 flex items-center gap-1" title="When data was last scraped">
								<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
								Updated {lastUpdated}
							</span>
						)}
					</h1>
					{issues && issues.length > 0 ? (
						<div id="issueList" class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-green-500 divide-y divide-gray-100 dark:divide-gray-800">
							{issues.map((issue: any) => <IssueCard issue={issue} />)}
						</div>
					) : (
						<p class="text-gray-500">No issues found.</p>
					)}
					<div id="noIssuesMsg" class="hidden text-gray-500 dark:text-gray-400 mt-4 p-4 bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-100 dark:border-gray-800 text-center">No issues match your search.</div>
					
					<div class="mt-6 flex justify-center">
						<button id="showMoreIssuesBtn" class="hidden px-6 py-2.5 bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-full text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-indigo-600 dark:hover:text-indigo-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors shadow-sm">
							Show More Issues
						</button>
					</div>
				</section>

				<!-- Repos Section -->
				<section>
					<h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2">
						Repositories
						<span id="repoCount" class="text-sm font-normal text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 px-2 py-0.5 rounded-full">{repos ? repos.length : 0}</span>
					</h2>
					{repos && repos.length > 0 ? (
						<div id="repoList" class="grid grid-cols-1 xl:grid-cols-2 gap-6">
							{repos.map((repo: any) => <RepoCard repo={repo} repoIssues={issuesByRepo.get(repo.full_name) ?? []} />)}
						</div>
					) : (
						<p class="text-gray-500">No repositories found.</p>
					)}
					<div id="noReposMsg" class="hidden text-gray-500 dark:text-gray-400 mt-4 p-4 bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-100 dark:border-gray-800 text-center">No repositories match your filter.</div>
					
					<div class="mt-6 flex justify-center">
						<button id="showMoreReposBtn" class="hidden px-6 py-2.5 bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-700 rounded-full text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-indigo-600 dark:hover:text-indigo-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors shadow-sm">
							Show More Repositories
						</button>
					</div>
				</section>

			</main>
		</div>
	</div>
</Layout>

<script is:inline src="/filter.js"></script>
