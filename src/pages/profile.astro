
---
import { auth } from '../lib/auth';
import { generateUniqueUsername } from '../lib/username-utils';
import { pool } from '../lib/db';

export const prerender = false;

const session = await auth.api.getSession({
    headers: Astro.request.headers
});

if (!session || !session.user) {
    return Astro.redirect('/login');
}

let username = session.user.username;

if (!username) {
    // Fallback: Generate and save if missing
    try {
        username = await generateUniqueUsername(session.user.name, session.user.email);
        const client = await pool.connect();
        await client.query('UPDATE "user" SET "username" = $1 WHERE id = $2', [username, session.user.id]);
        client.release();
    } catch (e) {
        console.error("Error generating username in profile fallback", e);
        // If fails, maybe redirect to an error page or show something?
        // For now, let's just stay here (which might cause issues if we rely on username)
    }
}

if (username) {
    return Astro.redirect(`/${username}`);
} else {
    // Should not happen unless DB error
    return Astro.redirect('/500'); 
}
---
